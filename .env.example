# Anthropic SDK uses Claude Code's auth by default (Pro/Max billing).
# No ANTHROPIC_API_KEY required when running through Claude Code CLI.

# BetterAuth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Linear — optional, enables the linear integration package
LINEAR_API_KEY=

# Override the data directory (default ~/.friday)
# FRIDAY_DATA_DIR=
