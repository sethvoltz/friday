#!/usr/bin/env bash
# Friday CLI shim — invokes the built CLI in packages/cli/dist/ through fnm
# so it runs under the pinned Node (.node-version). Add this directory to
# your PATH (e.g. in .zshrc / .bashrc):
#   export PATH="$HOME/Development/Seth/Friday/agent-friday/bin:$PATH"
#
# Resolves the pinned Node via fnm at invocation time and `exec`s that node
# binary in place, so the CLI runs without an fnm wrapper sitting on the
# process tree. fnm reads .node-version from CWD; we cd into the repo root
# (which holds .node-version) first.
set -euo pipefail
DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$DIR"
NODE_BIN="$("$(brew --prefix)/bin/fnm" exec -- command -v node)"
exec "${NODE_BIN}" "packages/cli/dist/index.js" "$@"
