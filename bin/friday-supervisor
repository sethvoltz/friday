#!/usr/bin/env bash
# friday-supervisor — launchd-supervised entrypoint for the Friday stack.
# Invoked by the launchd plist (com.sethvoltz.friday) written directly by
# install.sh / the friday CLI; not normally run by users directly.
# Execs through fnm so it runs under the pinned Node (.node-version) with no
# baked node path. See ADR-028 (FRI-88) + ADR-033 (FRI-146) for the design.
#
# fnm resolves .node-version from the CWD (it does NOT walk up parent dirs),
# so we cd into the install-tree root — which holds .node-version — before
# exec'ing. The plist also sets WorkingDirectory to the tree root, but this
# keeps the shim correct when run directly.
DIR="$(dirname "$0")"
cd "$DIR/.." || exit 1
exec "$(brew --prefix)/bin/fnm" exec -- node "packages/cli/dist/bin/supervisor.js" "$@"
