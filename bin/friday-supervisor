#!/usr/bin/env bash
# friday-supervisor — launchd-supervised entrypoint for the Friday stack.
# Invoked by the launchd plist (com.sethvoltz.friday) written by install.sh /
# the friday CLI; not normally run by users directly.
#
# Resolves the pinned Node via fnm at launch time (fnm reads .node-version
# from CWD — the plist's WorkingDirectory is the install root which holds
# .node-version, and this script cd's there too for the directly-invoked
# case). Then `exec`s the resolved node binary IN PLACE so the bash shim
# process is replaced by node — no spawn-and-wait wrapper sits on the
# launchd-tracked process for the supervisor's lifetime. The pinned Node is
# still the runtime-resolved fnm-managed one; we just don't keep fnm alive
# as a wrapper. See ADR-028 (FRI-88) + ADR-034 (FRI-146) for the design.
#
# fnm location: launchd-spawned processes don't inherit your shell's PATH,
# so we can't `command -v fnm` under launchd unless something puts the brew
# bin dir on PATH first. install.sh (and launchd.ts:renderPlist) resolve
# the fnm binary at install time and bake it into the plist's
# EnvironmentVariables.FRIDAY_FNM_BIN. This script reads that; for the
# directly-invoked / dev workflow case it falls back to `command -v fnm`,
# which works in interactive shells where brew is on PATH.
#
# PATH propagation to children (FRI-150): the plist's EnvironmentVariables
# also bakes `PATH=<brew-prefix>/bin:<brew-prefix>/sbin:/usr/bin:/bin:
# /usr/sbin:/sbin` (brew's `std_service_path_env` equivalent), so when this
# script execs node and node spawns children — daemon → workers → SDK →
# stdio MCP children — they inherit a useful PATH and `execvp("node")` /
# `execvp("npx")` for MCP manifests with relative commands resolves
# correctly. Without that, every launchd-supervised restart kills stdio
# MCP children with ENOENT. brew's pre-FRI-88 `service do` block did this
# under formula supervision; the custom-plist migration lost the layer.
set -euo pipefail
DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$DIR"
FNM_BIN="${FRIDAY_FNM_BIN:-$(command -v fnm || true)}"
if [ -z "${FNM_BIN}" ] || [ ! -x "${FNM_BIN}" ]; then
  echo "friday-supervisor: fnm not found (FRIDAY_FNM_BIN unset and not on PATH)" >&2
  exit 1
fi
NODE_BIN="$("${FNM_BIN}" exec -- command -v node)"
# `exec -a friday-supervisor` sets argv[0] on the resulting node process so
# `ps`, Activity Monitor, and macOS's "background activity" / Login Items
# prompt display "friday-supervisor" instead of "node" (or "fnm" under the
# pre-FRI-* plist). The actual binary is still the fnm-resolved pinned node.
exec -a "friday-supervisor" "${NODE_BIN}" "packages/cli/dist/bin/supervisor.js" "$@"
