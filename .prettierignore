# Build outputs
**/dist/**
**/build/**
**/.svelte-kit/**
**/.turbo/**
**/node_modules/**
**/coverage/**

# Generated migrations + lockfiles (Drizzle owns the journal format)
packages/shared/drizzle/**
pnpm-lock.yaml

# Test golden fixtures — byte-exact snapshots produced by the test
# itself (`JSON.stringify(t, null, 2)`). Prettier reformatting breaks
# the round-trip; the tests pin formatting through the serializer.
**/__golden__/**

# SvelteKit-generated client artifacts
services/dashboard/.svelte-kit/**
services/dashboard/build/**

# Friday-owned local data dir (never in repo, but defensive)
.friday/**

# Skip svelte files — handled by `pnpm --filter @friday/dashboard check`
*.svelte

# release-please owns CHANGELOG.md's format; do not prettier-check it
CHANGELOG.md
