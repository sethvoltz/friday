{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".svelte-kit/**", "build/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "@friday/daemon#dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "@friday/dashboard#dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
